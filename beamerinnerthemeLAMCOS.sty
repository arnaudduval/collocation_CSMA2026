\newlength\fillw
\fillw=0.3\textwidth
\advance \fillw by 2\beamer@leftmargin

\defbeamertemplate*{section page}{lamcos-split}{
	% \frame[plain]{
	\usebeamercolor{section in section page}
	\tikz[remember picture, overlay]{%
	\fill[color=bg](current page.north west) rectangle ([xshift=\fillw]current page.south west);
	}
	\begin{columns}[c,onlytextwidth]
		\column{0.3\textwidth}
		\centering
		\vbox to\LH{%
			\vfill%
			\pgfuseimage{lamcos-white}\vfill%
			}
		\vskip\baselineskip
		\usebeamerfont{section number in section page}\textcolor{fg}{\the\beamer@tocsectionnumber}\par%  \thesection gives wrong number with starred sections
		\ifx\insertsectiongraphic\empty%
			\vskip\baselineskip
			\usebeamerfont{section in section page}\textcolor{fg}{\MakeUppercase{\insertsection}}\par%
		\else%
			\vskip\baselineskip
			\insertsectiongraphic
		\column{0.5\textwidth}
			\tableofcontents[currentsection,hideothersubsections]
	\end{columns}
  	\tikzheadline
	% }
}
\newif\ifbeamer@theme@sectionpage
\DeclareOptionBeamer{sectionpage}[true]{\csname beamer@theme@sectionpage#1\endcsname}

\AtBeginSection[]{
	\ifbeamer@theme@sectionpage
		\frame[plain]{\sectionpage}
	\fi
}
