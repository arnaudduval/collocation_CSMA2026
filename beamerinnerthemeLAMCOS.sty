%
% The \sectiongraphic command inspired from \titlegraphic
%
%
\newcommand\sectiongraphic[1]{\def\insertsectiongraphic{%
	% #1	
	% \includegraphics[width=\linewidth,cfbox=white 1pt 1pt]{#1} % cframe= color rulewidth sep margin
	\ifx\relax#1\relax
		% parameter #1 is empty (no section graphic)
	\else
		\usebeamercolor{section in section page}
		\begin{tcolorbox}[skin=enhanced,
			left=0mm,right=0mm,top=0mm,bottom=0mm,boxsep=0pt, % the box fits the same of the graphic
			arc=0mm,% the box is rectangular
			frame hidden, interior hidden, % no frame nor bg color
			fuzzy halo=1pt with bg!95, % halo around the graphic
			outer arc=0.5mm, % the halo is a bit rounded
			]
			\includegraphics[width=\linewidth]{#1} % graphic
		\end{tcolorbox}
	\fi
	}
}
\sectiongraphic{}
