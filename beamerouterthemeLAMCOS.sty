% FRAMETITLE
% inspired from default theme: https://github.com/josephwright/beamer/blob/main/base/themes/outer/beamerouterthemedefault.sty

\newlength\FRTTLW %FRameTiTLe Width
\FRTTLW = \paperwidth
\advance\FRTTLW by -\HGW
\defbeamertemplate*{frametitle}{lamcos}
{%
  \ifbeamercolorempty[bg]{frametitle}{}{\nointerlineskip}%
  \vspace{\headlineskip}%
  \hspace{-\beamer@leftmargin}% from https://tex.stackexchange.com/a/558544
  \begin{beamercolorbox}[sep=0.3cm,left,wd=\FRTTLW]{frametitle}
    \usebeamerfont{frametitle}%
    \vbox{}\vskip-1ex%
    \if@tempswa\else\csname beamer@fteleft\endcsname\fi%
    \strut\insertframetitle\strut\par%
    {%
      \ifx\insertframesubtitle\@empty%
      \else%
      {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\strut\insertframesubtitle\strut\par}%
      \fi
    }%
    \vskip-1ex%
    \if@tempswa\else\vskip-.3cm\fi% set inside beamercolorbox... evil here...
  \end{beamercolorbox}%
}

%\setbeamertemplate{frametitle}[default][left] % use template from default theme, subtitle included (same background as title), left aligned
\setbeamertemplate{frametitle}[lamcos]

