% FOOTLINE


\newcommand{\tikzplus}{
  \tikz[baseline=0.25\SQRL,remember picture, overlay]{%
    \usebeamercolor{page number in head/foot}
    % light vertical lines above blue square (21)
    % \foreach \x in {0, 0.05\SQRL, ..., \SQRL} % it does not work, do not know why ...
    \foreach \x in {0,0.05\SQRL,0.1\SQRL,0.15\SQRL,0.20\SQRL,0.25\SQRL,0.3\SQRL,0.35\SQRL,%
    0.4\SQRL,0.45\SQRL,0.5\SQRL,0.55\SQRL,0.6\SQRL,0.65\SQRL,0.7\SQRL,0.75\SQRL,0.8\SQRL,%
    0.85\SQRL,0.9\SQRL,0.95\SQRL,\SQRL}
    \draw[solid,color=bg!20,line width=0.5\LW] (\x,\SQRL) -- ++(0,\SQRL);

    % colored vertical lines left of blue square
    \foreach \x/\y in {\SQRL/LAMCOSdblue, 0.75\SQRL/LAMCOSlblue, 0.5\SQRL/LAMCOSyellow, 0.25\SQRL/LAMCOSred}
    \draw[solid,color=\y,line width=\LW] (-\x,0) -- ++(0,\SQRL);

    % blue square with page number
    \fill[fill=bg,line width=\LW,draw=bg] (0,0) -- ++(0,\SQRL) -- ++(\SQRL,0) -- ++(0,-\SQRL) ;
    \draw (0.5\SQRL,0.5\SQRL) node[text=fg,anchor=center] (p) {%
      \usebeamerfont{page number in head/foot}\strut\insertframenumber\strut%
      };
    }%
  }

\newlength\LOGOSW
\LOGOSW = .53\paperwidth
\advance \LOGOSW by -0.5\beamer@rightmargin
\advance \LOGOSW by -2.25\SQRL
\defbeamertemplate{footline}{lamcos-plus-logos}
  {%
    \leavevmode%
    \hbox to \paperwidth{%
    \begin{beamercolorbox}[wd=0.47\paperwidth,ht=\SQRL,dp=0.5\SQRL,left,leftskip=2\beamer@leftmargin]{date in head/foot}%
      \usebeamerfont{date in head/foot} \insertdate
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=\LOGOSW,ht=\SQRL,dp=0.5\SQRL,left]{logos in head/foot}%
        \tikz[baseline=-0.25\SQRL]{
          \draw(0,0) node[anchor=center] (c) {\pgfuseimage{cnrs}};
          \draw(c.east) node[anchor=west] (i) {\pgfuseimage{insa}};
          \draw(i.east) node[anchor=west] (u) {\pgfuseimage{udl}};
          \draw(u.east) node[anchor=west] (ca) {\pgfuseimage{carnot}};
          }
    \end{beamercolorbox}%
    \hskip0pt plus 1fill
    \tikzplus%
    \hspace{\dimexpr0.5\beamer@rightmargin+\SQRL}
    }
}

\newlength\LOGOW
\settowidth{\LOGOW}{\pgfuseimage{lamcos-marque}}
\advance \LOGOW by \beamer@leftmargin

\newlength\DATEW
\DATEW = 0.2\paperwidth
\advance \DATEW by -.5\LOGOW

\newlength\AUTHORW
\AUTHORW = 0.3\paperwidth
\advance \AUTHORW by -.5\LOGOW

\newlength\TTLW
\TTLW = .5\paperwidth
\advance \TTLW by -0.5\beamer@rightmargin
\advance \TTLW by -2.25\SQRL

\defbeamertemplate*{footline}{lamcos-plus}
  {%
    \leavevmode%
    \hbox to \paperwidth{%
    \begin{beamercolorbox}[wd=\LOGOW,ht=\SQRL,dp=0.5\SQRL,left,leftskip=0.5\beamer@leftmargin]{logos in head/foot}%
      \raisebox{-0.25\SQRL}{%
        \pgfuseimage{lamcos-marque}%
        }%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=\DATEW,ht=\SQRL,dp=0.5\SQRL,center]{date in head/foot}%
      \centering\usebeamerfont{date in head/foot} \insertshortdate
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=\TTLW,ht=\SQRL,dp=0.5\SQRL,center]{title in head/foot}%
      \usebeamerfont{title in head/foot}%
      \insertshorttitle%
      %  \hfill%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=\AUTHORW,ht=\SQRL,dp=0.5\SQRL,center]{author in head/foot}%
        \ifx\insertinstitute\empty%
          \centering\usebeamerfont{author in head/foot} \insertshortauthor%
        \else%
          \centering\usebeamerfont{author in head/foot} \insertshortauthor{} (\insertshortinstitute)%
        \fi%
    \end{beamercolorbox}%
    \hskip0pt plus 1fill
    \tikzplus%
    \hspace{\dimexpr0.5\beamer@rightmargin+\SQRL}
    }%
}


