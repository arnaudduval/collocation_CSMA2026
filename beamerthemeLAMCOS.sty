% BIBLIOGRAPHY
\usepackage[backend=biber,
  style=numeric, % complete citations as footnote
  citetracker=false, % do not track whether an entry has been cited before --> full citation every time, see NOTE below
	date=year, % date are printed as year only (no day or month)
  url=false, % do not print url
  ]{biblatex}

% NOTE: Handle footnote citations and overlays
% when a citation appears on multiple slides, the full reference is shown
% on the first slide and a short reference is shown on the following slides
% this can break overlays as the length of the citation changes from
% one slide to the next, hence the height of the footnote area

% ADDITIONNAL CUSTOMIZATION: make verbose citation style lighter
\renewbibmacro{in:}{} % remove default "in: " (Article, in: Journal or Title, in: Book)
\renewcommand{\finalnamedelim}{\addspace\&\space} % Author1, Author2, & Author3
% Remove unnecessary fields from citations as they make the printed reference as footnote
% too lenghty for slides, but keep them in the reference list given by \printbibliography
% i.e. \AtEveryBibItem
\AtEveryCitekey{%
  \clearlist{language}%
  \clearfield{issn}%
  \clearfield{isbn}%
  \clearlist{publisher}%
  \clearfield{pages}%
  \clearfield{doi}%
  \clearfield{eprint}%
  \clearfield{eprinttype}%
}
% Shorten author names, print last names only
\DeclareNameFormat{family}{%
  \usebibmacro{name:family}
    {\namepartfamily}
    {\namepartgiven}
    {\namepartprefix}
    {\namepartsuffix}%
  \usebibmacro{name:andothers}
  }
\DeclareNameAlias{default}{family}
\DeclareNameAlias{sortname}{default}
\DeclareNameAlias{labelname}{default}
% Converts title fields to sentence case, i. e., the first word is capitalized and
% the remainder of the string is converted to lowercase.
% \DeclareFieldFormat{titlecase}{\MakeSentenceCase*{#1}} % sentence case on journal names as well...
\DeclareFieldFormat{sentencecase}{\MakeSentenceCase{#1}}
\renewbibmacro*{title}{%
  \ifthenelse{\iffieldundef{title}\AND\iffieldundef{subtitle}}
    {}
    {\ifthenelse{%
      \ifentrytype{article}\OR\ifentrytype{inbook}%
      \OR\ifentrytype{incollection}\OR\ifentrytype{inproceedings}%
      \OR\ifentrytype{inreference}\OR\ifentrytype{thesis}
      }
      {\printtext[title]{%
          \printfield[sentencecase]{title}%
          \setunit{\subtitlepunct}%
          \printfield[sentencecase]{subtitle}
          }
        }%
      {\printtext[title]{%
          \printfield[titlecase]{title}%
          \setunit{\subtitlepunct}%
          \printfield[titlecase]{subtitle}
          }
        }%
      \newunit
      }%
  \printfield{titleaddon}
  }

