%-------------------------------------------------------------------------------
% COUNTERS
% count number of sections apart from the appendix
% inspired from https://tex.stackexchange.com/a/357377
\usepackage{xassoccnt}% must be loaded after `calc', loaded for instance by `mathtools' above
% issues a warning, ignore it

\NewTotalDocumentCounter{appendixsections}
\NewTotalDocumentCounter{truesections}
\DeclareTotalAssociatedCounters{section}{truesections,totalsections}% declare `truesections' counter to be stepped
% simultaneously when the driver counter `section' is increased by \stepcounter

\preto\appendix{
    % stop increasing `truesections'
    \SuspendCounters{truesections}
    % start increasing `appendixsections' along with driver counet `section'
    \AddAssociatedCounters{section}{appendixsections}
}
