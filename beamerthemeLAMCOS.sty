% Gradient image for headline (top right corner decoration)
\pgfdeclareimage[height=1.125ex]{headline-gdt}{images/template/headline-gradient}
\newlength\HGH
\settoheight{\HGH}{\pgfuseimage{headline-gdt}}
\newlength\HGW
\settowidth{\HGW}{\pgfuseimage{headline-gdt}}

% Width of section area and section colorboxes in headline
\newlength\sectionwidth
\setlength{\sectionwidth}{\dimexpr(\paperwidth-\HGW)\relax}
% compute the width of the sections based on the number of sections (appendix excluded)
\newlength\sectionboxwd
\AtBeginDocument{%
  \ifnum\TotalValue{truesections}>0 % see definition of `truesections' in the COUNTERS section above
    \setlength\sectionboxwd{\dimexpr\sectionwidth/\TotalValue{truesections}-2.5ex\relax}
    % -2.5ex = -2 * 1.25ex = -2 * \fboxsep
  \else
    \setlength\sectionboxwd{\sectionwidth}
  \fi
}
